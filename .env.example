# ============================================================
#  Dump — пример переменных окружения.
#  Скопируйте в .env и заполните реальными значениями.
# ============================================================

# --- База данных (MySQL) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=dump_db
DB_USERNAME=root
DB_PASSWORD=

# --- Cloudflare Turnstile (капча на входе/регистрации) ---
# Site Key (публичный, встраивается в виджет) и Secret Key (серверная проверка).
# Получить: Cloudflare Dashboard → Turnstile.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Хостинг изображений imgbb ---
# https://api.imgbb.com/
IMGBB_API_KEY=

# --- Транзакционная почта Resend (коды 2FA) ---
# https://resend.com/api-keys
RESEND_API_KEY=

# --- Публичный базовый URL сервиса (для sitemap/SEO/canonical) ---
APP_URL=https://dump.press

# --- Контактная почта поддержки ---
SUPPORT_EMAIL=help@dump.press
